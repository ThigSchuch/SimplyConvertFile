#: src/simplyconvertfile/utils/text.py:138
msgid "Select one or more files to convert."
msgstr "Vyberte jeden nebo více souborů k převodu."

#: src/simplyconvertfile/utils/text.py:140
#, python-brace-format
msgid ""
"File not found:\n"
"{path}\n"
"\n"
"Check if the file exists."
msgstr ""
"Soubor nenalezen:\n"
"{path}\n"
"\n"
"Zkontrolujte, zda soubor existuje."

#: src/simplyconvertfile/utils/text.py:143
#, python-brace-format
msgid ""
"Invalid file:\n"
"{path}\n"
"\n"
"Select a file, not a folder."
msgstr ""
"Neplatný soubor:\n"
"{path}\n"
"\n"
"Vyberte soubor, ne složku."

#: src/simplyconvertfile/utils/text.py:146
#, python-brace-format
msgid ""
"No file extension:\n"
"{path}\n"
"\n"
"Add an extension (e.g., .jpg, .mp4, .pdf) to determine the format."
msgstr ""
"Žádná přípona souboru:\n"
"{path}\n"
"\n"
"Přidejte příponu (např. .jpg, .mp4, .pdf) pro určení formátu."

#: src/simplyconvertfile/utils/text.py:149
#, python-brace-format
msgid "Unsupported file format: {extension}"
msgstr "Nepodporovaný formát souboru: {extension}"

#: src/simplyconvertfile/utils/text.py:151
#, python-brace-format
msgid ""
"The file '{filename}' has an unsupported format ({extension}).\n"
"\n"
"This format is not recognized by the converter or the required tools are not "
"installed on your system."
msgstr ""
"Soubor '{filename}' má nepodporovaný formát ({extension}).\n"
"\n"
"Tento formát není rozpoznán převodníkem nebo požadované nástroje nejsou "
"nainstalovány ve vašem systému."

#: src/simplyconvertfile/utils/text.py:156
#, python-brace-format
msgid ""
"Found {error_count} validation error(s) in the selected files:\n"
"\n"
"{errors}\n"
"\n"
"The process will continue with valid files only."
msgstr ""
"Nalezeno {error_count} validačních chyb ve vybraných souborech:\n"
"\n"
"{errors}\n"
"\n"
"Proces bude pokračovat pouze s platnými soubory."

#: src/simplyconvertfile/utils/text.py:164
msgid "Conversion failed."
msgstr "Převod selhal."

#: src/simplyconvertfile/utils/text.py:165
msgid "No converter found for this format"
msgstr "Nenalezen žádný převodník pro tento formát"

#: src/simplyconvertfile/utils/text.py:167
#, python-brace-format
msgid ""
"No converters available for {extension} files.\n"
"\n"
"File: {filename}\n"
"\n"
"Possible causes:\n"
"• Missing rules\n"
"• Missing required tools\n"
"• Unsupported format\n"
"• Installation issue\n"
"\n"
"Check system dependencies."
msgstr ""
"Žádné převodníky nejsou k dispozici pro soubory {extension}.\n"
"\n"
"Soubor: {filename}\n"
"\n"
"Možné příčiny:\n"
"• Chybějící pravidla\n"
"• Chybějící požadované nástroje\n"
"• Nepodporovaný formát\n"
"• Problém s instalací\n"
"\n"
"Zkontrolujte závislosti systému."

#: src/simplyconvertfile/utils/text.py:177
#, python-brace-format
msgid ""
"Failed to create converter for {source} → {target}\n"
"\n"
"File: {file}\n"
"\n"
"This could indicate:\n"
"• Missing conversion tools\n"
"• Incompatible format combination\n"
"• System configuration issue"
msgstr ""
"Nepodařilo se vytvořit převodník pro {source} → {target}\n"
"\n"
"Soubor: {file}\n"
"\n"
"To může znamenat:\n"
"• Chybějící nástroje pro převod\n"
"• Nekompatibilní kombinace formátů\n"
"• Problém s konfigurací systému"

#: src/simplyconvertfile/utils/text.py:185
#, python-brace-format
msgid ""
"Converting {current} of {total} files to {extension}\n"
"{file}"
msgstr ""
"Převádění {current} z {total} souborů na {extension}\n"
"{file}"

#: src/simplyconvertfile/utils/text.py:188
#, python-brace-format
msgid ""
"Failed to create or access output directory.\n"
"\n"
"Error: {error}"
msgstr ""
"Nepodařilo se vytvořit nebo přistupovat k výstupnímu adresáři.\n"
"\n"
"Chyba: {error}"

#: src/simplyconvertfile/utils/text.py:190
#, python-brace-format
msgid "Conversion failed: {error}"
msgstr "Převod selhal: {error}"

#: src/simplyconvertfile/utils/text.py:191
msgid "Conversion cancelled by user"
msgstr "Převod zrušen uživatelem"

#: src/simplyconvertfile/utils/text.py:193
msgid ""
"Conversion failed - check if required tools are installed (e.g., ffmpeg, "
"convert, 7z, rar, etc.) and the file format is supported"
msgstr ""
"Převod selhal - zkontrolujte, zda jsou nainstalovány požadované nástroje "
"(např. ffmpeg, convert, 7z, rar atd.) a zda je formát souboru podporován"

#: src/simplyconvertfile/utils/text.py:196
#, python-brace-format
msgid "Template error: {error}"
msgstr "Chyba šablony: {error}"

#: src/simplyconvertfile/utils/text.py:201
#: src/simplyconvertfile/utils/text.py:292
#, python-brace-format
msgid "Required tool '{tool}' is not installed."
msgstr "Požadovaný nástroj '{tool}' není nainstalován."

#: src/simplyconvertfile/utils/text.py:203
#, python-brace-format
msgid "The conversion tool '{tool}' is required but not found on your system."
msgstr ""
"Převodní nástroj '{tool}' je požadován, ale nebyl nalezen ve vašem systému."

#: src/simplyconvertfile/utils/text.py:206
#, python-brace-format
msgid ""
"Missing Tool: {tool}\n"
"\n"
"Install Command:\n"
"{install_command}\n"
"\n"
"Instructions:\n"
"Copy the install command above and run it in your terminal. If the command "
"does not work, please refer to your distribution's package manager or the "
"tool's official installation instructions."
msgstr ""
"Chybějící nástroj: {tool}\n"
"\n"
"Instalační příkaz:\n"
"{install_command}\n"
"\n"
"Instrukce:\n"
"Zkopírujte instalační příkaz výše a spusťte jej v terminálu. Pokud příkaz "
"nefunguje, obraťte se na správce balíčků vaší distribuce nebo oficiální "
"instalační instrukce nástroje."

#: src/simplyconvertfile/utils/text.py:213
msgid "An unexpected error occurred during conversion."
msgstr "Během převodu došlo k neočekávané chybě."

#: src/simplyconvertfile/utils/text.py:215
msgid ""
"Required tool not found. Please make sure all required conversion tools are "
"installed (e.g., ffmpeg, convert, etc.)"
msgstr ""
"Požadovaný nástroj nebyl nalezen. Ujistěte se, že jsou nainstalovány všechny "
"požadované převodní nástroje (např. ffmpeg, convert atd.)"

