#: src/simplyconvertfile/utils/text.py:118
msgid "File Converter"
msgstr "Convertitore di File"

#: src/simplyconvertfile/utils/text.py:119
msgid "Choose output format:"
msgstr "Scegli formato di output:"

#: src/simplyconvertfile/utils/text.py:120
#, python-brace-format
msgid ""
"Converting\n"
"{file} to {extension}"
msgstr ""
"Conversione in corso\n"
"{file} in {extension}"

#: src/simplyconvertfile/utils/text.py:121
msgid "Copy Error"
msgstr "Copia Errore"

#: src/simplyconvertfile/utils/text.py:122
msgid "Copy Command"
msgstr "Copia Comando"

#: src/simplyconvertfile/utils/text.py:123
msgid "Report Error"
msgstr "Segnala Errore"

#: src/simplyconvertfile/utils/text.py:124
msgid "OK"
msgstr "OK"

#: src/simplyconvertfile/utils/text.py:125
msgid "Cancel"
msgstr "Annulla"

#: src/simplyconvertfile/utils/text.py:126
msgid "Cancelling..."
msgstr "Annullamento..."

#: src/simplyconvertfile/utils/text.py:127
msgid "Start"
msgstr "Avvia"

#: src/simplyconvertfile/utils/text.py:128
msgid "Error details copied to clipboard"
msgstr "Dettagli errore copiati negli appunti"

#: src/simplyconvertfile/utils/text.py:129
msgid "Install command copied to clipboard"
msgstr "Comando di installazione copiato negli appunti"

#: src/simplyconvertfile/utils/text.py:131
#, python-brace-format
msgid ""
"No installation instructions available. Please install '{dependency}' "
"manually."
msgstr ""
"Nessuna istruzione di installazione disponibile. Installa '{dependency}' "
"manualmente."

#: src/simplyconvertfile/utils/text.py:133
msgid "multiple files selected"
msgstr "file multipli selezionati"

#: src/simplyconvertfile/utils/text.py:138
msgid "Select one or more files to convert."
msgstr "Seleziona uno o più file da convertire."

#: src/simplyconvertfile/utils/text.py:140
#, python-brace-format
msgid ""
"File not found:\n"
"{path}\n"
"\n"
"Check if the file exists."
msgstr ""
"File non trovato:\n"
"{path}\n"
"\n"
"Verifica se il file esiste."

#: src/simplyconvertfile/utils/text.py:143
#, python-brace-format
msgid ""
"Invalid file:\n"
"{path}\n"
"\n"
"Select a file, not a folder."
msgstr ""
"File non valido:\n"
"{path}\n"
"\n"
"Seleziona un file, non una cartella."

#: src/simplyconvertfile/utils/text.py:146
#, python-brace-format
msgid ""
"No file extension:\n"
"{path}\n"
"\n"
"Add an extension (e.g., .jpg, .mp4, .pdf) to determine the format."
msgstr ""
"Nessuna estensione file:\n"
"{path}\n"
"\n"
"Aggiungi un'estensione (es. .jpg, .mp4, .pdf) per determinare il formato."

#: src/simplyconvertfile/utils/text.py:149
#, python-brace-format
msgid "Unsupported file format: {extension}"
msgstr "Formato file non supportato: {extension}"

#: src/simplyconvertfile/utils/text.py:151
#, python-brace-format
msgid ""
"The file '{filename}' has an unsupported format ({extension}).\n"
"\n"
"This format is not recognized by the converter or the required tools are not "
"installed on your system."
msgstr ""
"Il file '{filename}' ha un formato non supportato ({extension}).\n"
"\n"
"Questo formato non è riconosciuto dal convertitore o gli strumenti richiesti "
"non sono installati sul sistema."

#: src/simplyconvertfile/utils/text.py:156
#, python-brace-format
msgid ""
"Found {error_count} validation error(s) in the selected files:\n"
"\n"
"{errors}\n"
"\n"
"The process will continue with valid files only."
msgstr ""
"Trovati {error_count} errori di validazione nei file selezionati:\n"
"\n"
"{errors}\n"
"\n"
"Il processo continuerà solo con i file validi."

#: src/simplyconvertfile/utils/text.py:164
msgid "Conversion failed."
msgstr "Conversione fallita."

#: src/simplyconvertfile/utils/text.py:165
msgid "No converter found for this format"
msgstr "Nessun convertitore trovato per questo formato"

#: src/simplyconvertfile/utils/text.py:167
#, python-brace-format
msgid ""
"No converters available for {extension} files.\n"
"\n"
"File: {filename}\n"
"\n"
"Possible causes:\n"
"• Missing rules\n"
"• Missing required tools\n"
"• Unsupported format\n"
"• Installation issue\n"
"\n"
"Check system dependencies."
msgstr ""
"Nessun convertitore disponibile per i file {extension}.\n"
"\n"
"File: {filename}\n"
"\n"
"Possibili cause:\n"
"• Regole mancanti\n"
"• Strumenti richiesti mancanti\n"
"• Formato non supportato\n"
"• Problema di installazione\n"
"\n"
"Verifica le dipendenze del sistema."

#: src/simplyconvertfile/utils/text.py:177
#, python-brace-format
msgid ""
"Failed to create converter for {source} → {target}\n"
"\n"
"File: {file}\n"
"\n"
"This could indicate:\n"
"• Missing conversion tools\n"
"• Incompatible format combination\n"
"• System configuration issue"
msgstr ""
"Impossibile creare convertitore per {source} → {target}\n"
"\n"
"File: {file}\n"
"\n"
"Questo potrebbe indicare:\n"
"• Strumenti di conversione mancanti\n"
"• Combinazione di formati incompatibile\n"
"• Problema di configurazione del sistema"

#: src/simplyconvertfile/utils/text.py:185
#, python-brace-format
msgid ""
"Converting {current} of {total} files to {extension}\n"
"{file}"
msgstr ""
"Conversione {current} di {total} file in {extension}\n"
"{file}"

#: src/simplyconvertfile/utils/text.py:188
#, python-brace-format
msgid ""
"Failed to create or access output directory.\n"
"\n"
"Error: {error}"
msgstr ""
"Impossibile creare o accedere alla directory di output.\n"
"\n"
"Errore: {error}"

#: src/simplyconvertfile/utils/text.py:190
#, python-brace-format
msgid "Conversion failed: {error}"
msgstr "Conversione fallita: {error}"

#: src/simplyconvertfile/utils/text.py:191
msgid "Conversion cancelled by user"
msgstr "Conversione annullata dall'utente"

#: src/simplyconvertfile/utils/text.py:193
msgid ""
"Conversion failed - check if required tools are installed (e.g., ffmpeg, "
"convert, 7z, rar, etc.) and the file format is supported"
msgstr ""
"Conversione fallita - verifica se gli strumenti richiesti sono installati "
"(es. ffmpeg, convert, 7z, rar, ecc.) e se il formato file è supportato"

#: src/simplyconvertfile/utils/text.py:196
#, python-brace-format
msgid "Template error: {error}"
msgstr "Errore template: {error}"

#: src/simplyconvertfile/utils/text.py:201
#: src/simplyconvertfile/utils/text.py:292
#, python-brace-format
msgid "Required tool '{tool}' is not installed."
msgstr "Lo strumento richiesto '{tool}' non è installato."

#: src/simplyconvertfile/utils/text.py:203
#, python-brace-format
msgid "The conversion tool '{tool}' is required but not found on your system."
msgstr ""
"Lo strumento di conversione '{tool}' è richiesto ma non trovato sul sistema."

#: src/simplyconvertfile/utils/text.py:206
#, python-brace-format
msgid ""
"Missing Tool: {tool}\n"
"\n"
"Install Command:\n"
"{install_command}\n"
"\n"
"Instructions:\n"
"Copy the install command above and run it in your terminal. If the command "
"does not work, please refer to your distribution's package manager or the "
"tool's official installation instructions."
msgstr ""
"Strumento Mancante: {tool}\n"
"\n"
"Comando di Installazione:\n"
"{install_command}\n"
"\n"
"Istruzioni:\n"
"Copia il comando di installazione sopra ed eseguilo nel terminale. Se il "
"comando non funziona, fai riferimento al gestore pacchetti della tua "
"distribuzione o alle istruzioni di installazione ufficiali dello strumento."

#: src/simplyconvertfile/utils/text.py:213
msgid "An unexpected error occurred during conversion."
msgstr "Si è verificato un errore imprevisto durante la conversione."

#: src/simplyconvertfile/utils/text.py:215
msgid ""
"Required tool not found. Please make sure all required conversion tools are "
"installed (e.g., ffmpeg, convert, etc.)"
msgstr ""
"Strumento richiesto non trovato. Assicurati che tutti gli strumenti di "
"conversione richiesti siano installati (es. ffmpeg, convert, ecc.)"

