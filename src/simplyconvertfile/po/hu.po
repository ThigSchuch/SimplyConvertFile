#: src/simplyconvertfile/utils/text.py:126
msgid "Cancelling..."
msgstr "Megszakítás..."

#: src/simplyconvertfile/utils/text.py:127
msgid "Start"
msgstr "Indítás"

#: src/simplyconvertfile/utils/text.py:128
msgid "Error details copied to clipboard"
msgstr "A hiba részletei a vágólapra másolva"

#: src/simplyconvertfile/utils/text.py:129
msgid "Install command copied to clipboard"
msgstr "A telepítési parancs a vágólapra másolva"

#: src/simplyconvertfile/utils/text.py:131
#, python-brace-format
msgid ""
"No installation instructions available. Please install '{dependency}' "
"manually."
msgstr ""
"Nincsenek telepítési utasítások. Kérjük, telepítse manuálisan a "
"'{dependency}' függőséget."

#: src/simplyconvertfile/utils/text.py:133
msgid "multiple files selected"
msgstr "több fájl kiválasztva"

#: src/simplyconvertfile/utils/text.py:138
msgid "Select one or more files to convert."
msgstr "Válasszon ki egy vagy több konvertálandó fájlt."

#: src/simplyconvertfile/utils/text.py:140
#, python-brace-format
msgid ""
"File not found:\n"
"{path}\n"
"\n"
"Check if the file exists."
msgstr ""
"Fájl nem található:\n"
"{path}\n"
"\n"
"Ellenőrizze, hogy a fájl létezik-e."

#: src/simplyconvertfile/utils/text.py:143
#, python-brace-format
msgid ""
"Invalid file:\n"
"{path}\n"
"\n"
"Select a file, not a folder."
msgstr ""
"Érvénytelen fájl:\n"
"{path}\n"
"\n"
"Válasszon fájlt, ne mappát."

#: src/simplyconvertfile/utils/text.py:146
#, python-brace-format
msgid ""
"No file extension:\n"
"{path}\n"
"\n"
"Add an extension (e.g., .jpg, .mp4, .pdf) to determine the format."
msgstr ""
"Nincs fájlkiterjesztés:\n"
"{path}\n"
"\n"
"Adjon hozzá kiterjesztést (pl. .jpg, .mp4, .pdf) a formátum meghatározásához."

#: src/simplyconvertfile/utils/text.py:149
#, python-brace-format
msgid "Unsupported file format: {extension}"
msgstr "Nem támogatott fájlformátum: {extension}"

#: src/simplyconvertfile/utils/text.py:151
#, python-brace-format
msgid ""
"The file '{filename}' has an unsupported format ({extension}).\n"
"\n"
"This format is not recognized by the converter or the required tools are not "
"installed on your system."
msgstr ""
"A '{filename}' fájl nem támogatott formátumú ({extension}).\n"
"\n"
"Ezt a formátumot nem ismeri fel a konvertáló, vagy a szükséges eszközök "
"nincsenek telepítve a rendszeren."

#: src/simplyconvertfile/utils/text.py:156
#, python-brace-format
msgid ""
"Found {error_count} validation error(s) in the selected files:\n"
"\n"
"{errors}\n"
"\n"
"The process will continue with valid files only."
msgstr ""
"{error_count} érvényesítési hiba található a kiválasztott fájlokban:\n"
"\n"
"{errors}\n"
"\n"
"A folyamat csak az érvényes fájlokkal folytatódik."

#: src/simplyconvertfile/utils/text.py:164
msgid "Conversion failed."
msgstr "A konvertálás sikertelen."

#: src/simplyconvertfile/utils/text.py:165
msgid "No converter found for this format"
msgstr "Nem található konvertáló ehhez a formátumhoz"

#: src/simplyconvertfile/utils/text.py:167
#, python-brace-format
msgid ""
"No converters available for {extension} files.\n"
"\n"
"File: {filename}\n"
"\n"
"Possible causes:\n"
"• Missing rules\n"
"• Missing required tools\n"
"• Unsupported format\n"
"• Installation issue\n"
"\n"
"Check system dependencies."
msgstr ""
"Nincsenek elérhető konvertálók a {extension} fájlokhoz.\n"
"\n"
"Fájl: {filename}\n"
"\n"
"Lehetséges okok:\n"
"• Hiányzó szabályok\n"
"• Hiányzó szükséges eszközök\n"
"• Nem támogatott formátum\n"
"• Telepítési probléma\n"
"\n"
"Ellenőrizze a rendszerfüggőségeket."

#: src/simplyconvertfile/utils/text.py:177
#, python-brace-format
msgid ""
"Failed to create converter for {source} → {target}\n"
"\n"
"File: {file}\n"
"\n"
"This could indicate:\n"
"• Missing conversion tools\n"
"• Incompatible format combination\n"
"• System configuration issue"
msgstr ""
"Nem sikerült létrehozni a konvertálót a {source} → {target} számára\n"
"\n"
"Fájl: {file}\n"
"\n"
"Ez jelezheti:\n"
"• Hiányzó konvertálási eszközök\n"
"• Inkompatibilis formátum kombináció\n"
"• Rendszerkonfigurációs probléma"

#: src/simplyconvertfile/utils/text.py:185
#, python-brace-format
msgid ""
"Converting {current} of {total} files to {extension}\n"
"{file}"
msgstr ""
"{current}/{total} fájl konvertálása {extension} formátumba\n"
"{file}"

#: src/simplyconvertfile/utils/text.py:188
#, python-brace-format
msgid ""
"Failed to create or access output directory.\n"
"\n"
"Error: {error}"
msgstr ""
"Nem sikerült létrehozni vagy elérni a kimeneti könyvtárat.\n"
"\n"
"Hiba: {error}"

#: src/simplyconvertfile/utils/text.py:190
#, python-brace-format
msgid "Conversion failed: {error}"
msgstr "Konvertálás sikertelen: {error}"

#: src/simplyconvertfile/utils/text.py:191
msgid "Conversion cancelled by user"
msgstr "A konvertálást a felhasználó megszakította"

#: src/simplyconvertfile/utils/text.py:193
msgid ""
"Conversion failed - check if required tools are installed (e.g., ffmpeg, "
"convert, 7z, rar, etc.) and the file format is supported"
msgstr ""
"A konvertálás sikertelen - ellenőrizze, hogy a szükséges eszközök telepítve "
"vannak-e (pl. ffmpeg, convert, 7z, rar, stb.) és a fájlformátum támogatott"

#: src/simplyconvertfile/utils/text.py:196
#, python-brace-format
msgid "Template error: {error}"
msgstr "Sablon hiba: {error}"

#: src/simplyconvertfile/utils/text.py:201
#: src/simplyconvertfile/utils/text.py:292
#, python-brace-format
msgid "Required tool '{tool}' is not installed."
msgstr "A szükséges '{tool}' eszköz nincs telepítve."

#: src/simplyconvertfile/utils/text.py:203
#, python-brace-format
msgid "The conversion tool '{tool}' is required but not found on your system."
msgstr ""
"A '{tool}' konvertálási eszköz szükséges, de nem található a rendszeren."

#: src/simplyconvertfile/utils/text.py:206
#, python-brace-format
msgid ""
"Missing Tool: {tool}\n"
"\n"
"Install Command:\n"
"{install_command}\n"
"\n"
"Instructions:\n"
"Copy the install command above and run it in your terminal. If the command "
"does not work, please refer to your distribution's package manager or the "
"tool's official installation instructions."
msgstr ""
"Hiányzó eszköz: {tool}\n"
"\n"
"Telepítési parancs:\n"
"{install_command}\n"
"\n"
"Utasítások:\n"
"Másolja a fenti telepítési parancsot és futtassa a terminálban. Ha a parancs "
"nem működik, forduljon a disztribúció csomagkezelőjéhez vagy az eszköz "
"hivatalos telepítési útmutatójához."

#: src/simplyconvertfile/utils/text.py:213
msgid "An unexpected error occurred during conversion."
msgstr "Váratlan hiba történt a konvertálás során."

#: src/simplyconvertfile/utils/text.py:215
msgid ""
"Required tool not found. Please make sure all required conversion tools are "
"installed (e.g., ffmpeg, convert, etc.)"
msgstr ""
"Szükséges eszköz nem található. Győződjön meg arról, hogy minden szükséges "
"konvertálási eszköz telepítve van (pl. ffmpeg, convert, stb.)"

#: src/simplyconvertfile/utils/text.py:219
#, python-brace-format
msgid ""
"Shell command execution failed.\n"
"\n"
"Error: {error}\n"
"\n"
"Command: {command}"
msgstr ""
"A shell parancs végrehajtása sikertelen.\n"
"\n"
"Hiba: {error}\n"
"\n"
"Parancs: {command}"

#: src/simplyconvertfile/utils/text.py:222
#, python-brace-format
msgid ""
"Chained command execution failed.\n"
"\n"
"Error: {error}\n"
"\n"
"Command: {command}"
msgstr ""
"A láncolt parancs végrehajtása sikertelen.\n"
"\n"
"Hiba: {error}\n"
"\n"
"Parancs: {command}"

