#: src/simplyconvertfile/utils/text.py:118
msgid "File Converter"
msgstr "Convertisseur de fichiers"

#: src/simplyconvertfile/utils/text.py:119
msgid "Choose output format:"
msgstr "Choisir le format de sortie :"

#: src/simplyconvertfile/utils/text.py:120
#, python-brace-format
msgid ""
"Converting\n"
"{file} to {extension}"
msgstr ""
"Conversion en cours\n"
"{file} vers {extension}"

#: src/simplyconvertfile/utils/text.py:121
msgid "Copy Error"
msgstr "Copier l'erreur"

#: src/simplyconvertfile/utils/text.py:122
msgid "Copy Command"
msgstr "Copier la commande"

#: src/simplyconvertfile/utils/text.py:123
msgid "Report Error"
msgstr "Signaler l'erreur"

#: src/simplyconvertfile/utils/text.py:124
msgid "OK"
msgstr "OK"

#: src/simplyconvertfile/utils/text.py:125
msgid "Cancel"
msgstr "Annuler"

#: src/simplyconvertfile/utils/text.py:126
msgid "Cancelling..."
msgstr "Annulation..."

#: src/simplyconvertfile/utils/text.py:127
msgid "Start"
msgstr "Démarrer"

#: src/simplyconvertfile/utils/text.py:128
msgid "Error details copied to clipboard"
msgstr "Détails de l'erreur copiés dans le presse-papiers"

#: src/simplyconvertfile/utils/text.py:129
msgid "Install command copied to clipboard"
msgstr "Commande d'installation copiée dans le presse-papiers"

#: src/simplyconvertfile/utils/text.py:131
#, python-brace-format
msgid ""
"No installation instructions available. Please install '{dependency}' "
"manually."
msgstr ""
"Aucune instruction d'installation disponible. Veuillez installer "
"'{dependency}' manuellement."

#: src/simplyconvertfile/utils/text.py:133
msgid "multiple files selected"
msgstr "plusieurs fichiers sélectionnés"

#: src/simplyconvertfile/utils/text.py:138
msgid "Select one or more files to convert."
msgstr "Sélectionnez un ou plusieurs fichiers à convertir."

#: src/simplyconvertfile/utils/text.py:140
#, python-brace-format
msgid ""
"File not found:\n"
"{path}\n"
"\n"
"Check if the file exists."
msgstr ""
"Fichier introuvable :\n"
"{path}\n"
"\n"
"Vérifiez si le fichier existe."

#: src/simplyconvertfile/utils/text.py:143
#, python-brace-format
msgid ""
"Invalid file:\n"
"{path}\n"
"\n"
"Select a file, not a folder."
msgstr ""
"Fichier invalide :\n"
"{path}\n"
"\n"
"Sélectionnez un fichier, pas un dossier."

#: src/simplyconvertfile/utils/text.py:146
#, python-brace-format
msgid ""
"No file extension:\n"
"{path}\n"
"\n"
"Add an extension (e.g., .jpg, .mp4, .pdf) to determine the format."
msgstr ""
"Aucune extension de fichier :\n"
"{path}\n"
"\n"
"Ajoutez une extension (par exemple .jpg, .mp4, .pdf) pour déterminer le "
"format."

#: src/simplyconvertfile/utils/text.py:149
#, python-brace-format
msgid "Unsupported file format: {extension}"
msgstr "Format de fichier non pris en charge : {extension}"

#: src/simplyconvertfile/utils/text.py:151
#, python-brace-format
msgid ""
"The file '{filename}' has an unsupported format ({extension}).\n"
"\n"
"This format is not recognized by the converter or the required tools are not "
"installed on your system."
msgstr ""
"Le fichier '{filename}' a un format non pris en charge ({extension}).\n"
"\n"
"Ce format n'est pas reconnu par le convertisseur ou les outils requis ne "
"sont pas installés sur votre système."

#: src/simplyconvertfile/utils/text.py:156
#, python-brace-format
msgid ""
"Found {error_count} validation error(s) in the selected files:\n"
"\n"
"{errors}\n"
"\n"
"The process will continue with valid files only."
msgstr ""
"Trouvé {error_count} erreur(s) de validation dans les fichiers "
"sélectionnés :\n"
"\n"
"{errors}\n"
"\n"
"Le processus continuera uniquement avec les fichiers valides."

#: src/simplyconvertfile/utils/text.py:164
msgid "Conversion failed."
msgstr "Échec de la conversion."

#: src/simplyconvertfile/utils/text.py:165
msgid "No converter found for this format"
msgstr "Aucun convertisseur trouvé pour ce format"

#: src/simplyconvertfile/utils/text.py:167
#, python-brace-format
msgid ""
"No converters available for {extension} files.\n"
"\n"
"File: {filename}\n"
"\n"
"Possible causes:\n"
"• Missing rules\n"
"• Missing required tools\n"
"• Unsupported format\n"
"• Installation issue\n"
"\n"
"Check system dependencies."
msgstr ""
"Aucun convertisseur disponible pour les fichiers {extension}.\n"
"\n"
"Fichier : {filename}\n"
"\n"
"Causes possibles :\n"
"• Règles manquantes\n"
"• Outils requis manquants\n"
"• Format non pris en charge\n"
"• Problème d'installation\n"
"\n"
"Vérifiez les dépendances système."

#: src/simplyconvertfile/utils/text.py:177
#, python-brace-format
msgid ""
"Failed to create converter for {source} → {target}\n"
"\n"
"File: {file}\n"
"\n"
"This could indicate:\n"
"• Missing conversion tools\n"
"• Incompatible format combination\n"
"• System configuration issue"
msgstr ""
"Échec de la création du convertisseur pour {source} → {target}\n"
"\n"
"Fichier : {file}\n"
"\n"
"Cela peut indiquer :\n"
"• Outils de conversion manquants\n"
"• Combinaison de formats incompatible\n"
"• Problème de configuration système"

#: src/simplyconvertfile/utils/text.py:185
#, python-brace-format
msgid ""
"Converting {current} of {total} files to {extension}\n"
"{file}"
msgstr ""
"Conversion de {current} sur {total} fichiers vers {extension}\n"
"{file}"

#: src/simplyconvertfile/utils/text.py:188
#, python-brace-format
msgid ""
"Failed to create or access output directory.\n"
"\n"
"Error: {error}"
msgstr ""
"Échec de la création ou de l'accès au répertoire de sortie.\n"
"\n"
"Erreur : {error}"

#: src/simplyconvertfile/utils/text.py:190
#, python-brace-format
msgid "Conversion failed: {error}"
msgstr "Échec de la conversion : {error}"

#: src/simplyconvertfile/utils/text.py:191
msgid "Conversion cancelled by user"
msgstr "Conversion annulée par l'utilisateur"

#: src/simplyconvertfile/utils/text.py:193
msgid ""
"Conversion failed - check if required tools are installed (e.g., ffmpeg, "
"convert, 7z, rar, etc.) and the file format is supported"
msgstr ""
"Échec de la conversion - vérifiez si les outils requis sont installés (par "
"exemple ffmpeg, convert, 7z, rar, etc.) et si le format de fichier est pris "
"en charge"

#: src/simplyconvertfile/utils/text.py:196
#, python-brace-format
msgid "Template error: {error}"
msgstr "Erreur de modèle : {error}"

#: src/simplyconvertfile/utils/text.py:201
#: src/simplyconvertfile/utils/text.py:292
#, python-brace-format
msgid "Required tool '{tool}' is not installed."
msgstr "L'outil requis '{tool}' n'est pas installé."

#: src/simplyconvertfile/utils/text.py:203
#, python-brace-format
msgid "The conversion tool '{tool}' is required but not found on your system."
msgstr ""
"L'outil de conversion '{tool}' est requis mais introuvable sur votre système."

#: src/simplyconvertfile/utils/text.py:206
#, python-brace-format
msgid ""
"Missing Tool: {tool}\n"
"\n"
"Install Command:\n"
"{install_command}\n"
"\n"
"Instructions:\n"
"Copy the install command above and run it in your terminal. If the command "
"does not work, please refer to your distribution's package manager or the "
"tool's official installation instructions."
msgstr ""
"Outil manquant : {tool}\n"
"\n"
"Commande d'installation :\n"
"{install_command}\n"
"\n"
"Instructions :\n"
"Copiez la commande d'installation ci-dessus et exécutez-la dans votre "
"terminal. Si la commande ne fonctionne pas, reportez-vous au gestionnaire de "
"paquets de votre distribution ou aux instructions d'installation officielles "
"de l'outil."

#: src/simplyconvertfile/utils/text.py:213
msgid "An unexpected error occurred during conversion."
msgstr "Une erreur inattendue s'est produite lors de la conversion."

#: src/simplyconvertfile/utils/text.py:215
msgid ""
"Required tool not found. Please make sure all required conversion tools are "
"installed (e.g., ffmpeg, convert, etc.)"
msgstr ""
"Outil requis introuvable. Veuillez vous assurer que tous les outils de "
"conversion requis sont installés (par exemple ffmpeg, convert, etc.)"

#: src/simplyconvertfile/utils/text.py:219
#, python-brace-format
msgid ""
"Shell command execution failed.\n"
"\n"
"Error: {error}\n"
"\n"
"Command: {command}"
msgstr ""
"Échec de l'exécution de la commande shell.\n"
"\n"
"Erreur : {error}\n"
"\n"
"Commande : {command}"

