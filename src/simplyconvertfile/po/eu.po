msgid "Select one or more files to convert."
msgstr "Hautatu bihurtzeko fitxategi bat edo gehiago."

#: src/simplyconvertfile/utils/text.py:140
#, python-brace-format
msgid ""
"File not found:\n"
"{path}\n"
"\n"
"Check if the file exists."
msgstr ""
"Fitxategia ez da aurkitu:\n"
"{path}\n"
"\n"
"Egiaztatu fitxategia existitzen den."

