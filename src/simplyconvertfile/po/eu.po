msgid "No converter found for this format"
msgstr "Ez da bihurtzailerik aurkitu formatu honetarako"

#: src/simplyconvertfile/utils/text.py:167
#, python-brace-format
msgid ""
"No converters available for {extension} files.\n"
"\n"
"File: {filename}\n"
"\n"
"Possible causes:\n"
"• Missing rules\n"
"• Missing required tools\n"
"• Unsupported format\n"
"• Installation issue\n"
"\n"
"Check system dependencies."
msgstr ""
"Ez dago bihurtzailerik eskuragarri {extension} fitxategientzako.\n"
"\n"
"Fitxategia: {filename}\n"
"\n"
"Arrazoi posibleak:\n"
"• Arauak falta dira\n"
"• Beharrezko tresnak falta dira\n"
"• Onartu gabeko formatua\n"
"• Instalazio arazoa\n"
"\n"
"Egiaztatu sistema mendekotasunak."

#: src/simplyconvertfile/utils/text.py:177
#, python-brace-format
msgid ""
"Failed to create converter for {source} → {target}\n"
"\n"
"File: {file}\n"
"\n"
