"Invalid file:\n"
"{path}\n"
"\n"
"Select a file, not a folder."
msgstr ""
"Fitxategi baliogabea:\n"
"{path}\n"
"\n"
"Hautatu fitxategi bat, ez karpeta bat."

#: src/simplyconvertfile/utils/text.py:146
#, python-brace-format
msgid ""
"No file extension:\n"
"{path}\n"
"\n"
"Add an extension (e.g., .jpg, .mp4, .pdf) to determine the format."
msgstr ""
"Ez dago fitxategi luzapenik:\n"
"{path}\n"
"\n"
"Gehitu luzapen bat (adib. .jpg, .mp4, .pdf) formatua zehazteko."

